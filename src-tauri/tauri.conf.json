{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Vibe Island",
  "version": "0.1.0",
  "identifier": "com.vibeisland.app",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:5187",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Vibe Island",
        "width": 420,
        "height": 60,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "alwaysOnTop": true,
        "visible": true
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.ico",
      "iconAsTemplate": false,
      "id": "main-tray"
    },
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "nsis": {
        "installMode": "currentUser",
        "languages": ["en-US", "zh-CN"],
        "displayLanguageSelector": true
      }
    }
  }
}